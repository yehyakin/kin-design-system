{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KIN Agent informative locale source",
  "$defs": {
    "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "copy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "heading", "summary", "do", "do_not", "review"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
        "heading": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "do": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "do_not": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "labels": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
        "review": {"$ref": "#/$defs/review"}
      }
    },
    "review": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reviewers", "normative_source_checksum", "localized_content_checksum"],
          "properties": {
            "status": {"const": "reviewed"},
            "reviewers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^(?:@[A-Za-z0-9][A-Za-z0-9-]{0,38}|[a-z0-9][a-z0-9._-]{2,63})$"}},
            "normative_source_checksum": {"$ref": "#/$defs/hash"},
            "localized_content_checksum": {"$ref": "#/$defs/hash"},
            "reviewed_ref": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reviewers", "normative_source_checksum", "localized_content_checksum"],
          "properties": {
            "status": {"const": "unreviewed"},
            "reviewers": {"type": "array", "maxItems": 0},
            "normative_source_checksum": {"type": "null"},
            "localized_content_checksum": {"type": "null"}
          }
        }
      ]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "kind", "artifact_status", "normative", "locale", "direction", "rules"],
  "properties": {
    "$schema": {"const": "../schemas/locale-source.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "kind": {"const": "kin-agent-locale-source"},
    "artifact_status": {"const": "informative-translation-input"},
    "normative": {"const": false},
    "locale": {"enum": ["en", "zh-CN"]},
    "direction": {"const": "ltr"},
    "rules": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/copy"}}
  }
}
