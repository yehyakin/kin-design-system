{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KIN Agent design snapshot frontmatter",
  "$defs": {
    "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "tokenObject": {"type": "object", "minProperties": 1, "additionalProperties": true},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewers", "normative_source_checksum", "localized_content_checksum"],
      "properties": {
        "status": {"enum": ["reviewed", "unreviewed"]},
        "reviewers": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "normative_source_checksum": {"$ref": "#/$defs/hash"},
        "localized_content_checksum": {"$ref": "#/$defs/hash"}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schema_version", "schema_locator", "generated", "normative", "artifact_status", "editable", "publication", "kin_version", "release_status", "latest_stable_contract", "channel", "locale", "direction", "theme", "contrast", "coverage", "features", "locale_review", "source", "manifest_locator", "full_contract_path", "visual_signature_path", "delivery_contract_path", "product_profiles", "rules", "colors", "typography", "spacing", "rounded", "motion", "component_recipes"],
  "properties": {
    "kind": {"const": "kin-agent-design"},
    "schema_version": {"const": "1.0.0"},
    "schema_locator": {"const": "schemas/snapshot.schema.json"},
    "generated": {"const": true},
    "normative": {"const": false},
    "artifact_status": {"const": "generated-derivative"},
    "editable": {"const": false},
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "published", "public_locators"],
      "properties": {"state": {"const": "repository-only"}, "published": {"const": false}, "public_locators": {"const": "reserved-for-phase-2"}}
    },
    "kin_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "release_status": {"enum": ["development", "released"]},
    "latest_stable_contract": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "channel": {"const": "next"},
    "locale": {"enum": ["en", "zh-CN"]},
    "direction": {"const": "ltr"},
    "theme": {"enum": ["light", "dark"]},
    "contrast": {"enum": ["normal", "more"]},
    "coverage": {"const": "compact-foundations-and-routing"},
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_recipes"],
      "properties": {"component_recipes": {"const": "unavailable"}}
    },
    "locale_review": {"$ref": "#/$defs/review"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_path", "checksum_algorithm", "checksum", "input_set_checksum", "ref", "revision_status"],
      "properties": {
        "contract_path": {"const": "DESIGN.md"},
        "checksum_algorithm": {"const": "sha256"},
        "checksum": {"$ref": "#/$defs/hash"},
        "input_set_checksum": {"$ref": "#/$defs/hash"},
        "ref": {"const": "main"},
        "revision_status": {"const": "mutable"}
      }
    },
    "manifest_locator": {"const": "design-manifest.json"},
    "full_contract_path": {"const": "DESIGN.md"},
    "visual_signature_path": {"const": "principles/visual-signature.md"},
    "delivery_contract_path": {"const": "DELIVERY.md"},
    "product_profiles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}},
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "level", "source_path", "source_heading"],
        "properties": {
          "id": {"type": "string"},
          "level": {"enum": ["must", "must-not", "should", "may"]},
          "source_path": {"type": "string"},
          "source_heading": {"type": "string"}
        }
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canvas", "sidebar", "surface-1", "surface-2", "surface-3", "surface-4", "surface-hover", "surface-selected", "surface-overlay", "text-primary", "text-secondary", "text-muted", "text-disabled", "text-inverse", "icon-primary", "icon-muted", "line-subtle", "line-default", "line-strong", "accent", "accent-hover", "accent-active", "accent-soft", "focus-ring", "monitor", "monitor-soft", "positive", "warning", "negative", "critical", "offline"],
      "properties": {
        "canvas": {"type": "string"}, "sidebar": {"type": "string"},
        "surface-1": {"type": "string"}, "surface-2": {"type": "string"}, "surface-3": {"type": "string"}, "surface-4": {"type": "string"},
        "surface-hover": {"type": "string"}, "surface-selected": {"type": "string"}, "surface-overlay": {"type": "string"},
        "text-primary": {"type": "string"}, "text-secondary": {"type": "string"}, "text-muted": {"type": "string"}, "text-disabled": {"type": "string"}, "text-inverse": {"type": "string"},
        "icon-primary": {"type": "string"}, "icon-muted": {"type": "string"},
        "line-subtle": {"type": "string"}, "line-default": {"type": "string"}, "line-strong": {"type": "string"},
        "accent": {"type": "string"}, "accent-hover": {"type": "string"}, "accent-active": {"type": "string"}, "accent-soft": {"type": "string"},
        "focus-ring": {"type": "string"}, "monitor": {"type": "string"}, "monitor-soft": {"type": "string"},
        "positive": {"type": "string"}, "warning": {"type": "string"}, "negative": {"type": "string"}, "critical": {"type": "string"}, "offline": {"type": "string"}
      }
    },
    "typography": {"$ref": "#/$defs/tokenObject"},
    "spacing": {"$ref": "#/$defs/tokenObject"},
    "rounded": {"$ref": "#/$defs/tokenObject"},
    "motion": {"$ref": "#/$defs/tokenObject"},
    "component_recipes": {"type": "null"}
  }
}
