{
  "name": "kin-design-system",
  "version": "3.0.0",
  "description": "Design contracts, tokens, reference interfaces, and review tooling for information-rich products.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yehyakin/kin-design-system.git"
  },
  "engines": {
    "node": ">=20.11"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-docs.mjs && node scripts/validate-design.mjs && node scripts/validate-components.mjs && node scripts/validate-pages.mjs && node scripts/validate-scenarios.mjs && node scripts/validate-integrations.mjs && npm run release:check:pre-tag && node scripts/export-tokens.mjs --check && node scripts/export-figma-variables.mjs --check && npm run agent:check:generated",
    "release:check:pre-tag": "node scripts/validate-release.mjs --pre-tag",
    "release:check:post-tag": "node scripts/validate-release.mjs",
    "tokens:export": "node scripts/export-tokens.mjs",
    "tokens:check": "node scripts/export-tokens.mjs --check && node scripts/export-figma-variables.mjs --check",
    "tokens:figma": "node scripts/export-figma-variables.mjs",
    "agent:export": "npm run tokens:export && node scripts/export-agent-distribution.mjs",
    "agent:check:generated": "node scripts/export-agent-distribution.mjs --check && node scripts/validate-agent-distribution.mjs",
    "agent:check": "npm run tokens:check && npm run agent:check:generated",
    "components:check": "node scripts/validate-components.mjs",
    "pages:check": "node scripts/validate-pages.mjs",
    "scenarios:check": "node scripts/validate-scenarios.mjs",
    "site:build": "npm run runtime:build && node scripts/build-site.mjs",
    "site:check": "npm run agent:check && npm run runtime:build && node scripts/build-site.mjs && node scripts/validate-site.mjs",
    "site:serve": "npm run runtime:build && node scripts/build-site.mjs && node scripts/serve-site.mjs",
    "adoption:init": "node scripts/init-adoption.mjs",
    "adoption:check": "node scripts/check-adoption.mjs",
    "test:reference": "playwright test",
    "test:reference:chromium": "playwright test --project=chromium-reduced --project=chromium-normal-motion",
    "test:reference:smoke": "playwright test --project=firefox-smoke --project=webkit-smoke",
    "test:reference:update": "playwright test --update-snapshots",
    "runtime:build": "npm run build --workspace @kin-design/react",
    "runtime:check": "npm run check --workspace @kin-design/react",
    "runtime:compat": "node scripts/test-react-compatibility.mjs",
    "test:tooling": "node --test tests/tooling.test.mjs tests/agent-distribution.test.mjs",
    "audit": "node scripts/audit-project.mjs"
  },
  "devDependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@google/design.md": "0.3.0",
    "@number-flow/react": "0.6.2",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "cmdk": "1.1.1",
    "esbuild": "0.28.1",
    "input-otp": "1.4.2",
    "leva": "0.10.1",
    "liveline": "0.0.7",
    "lucide": "1.25.0",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-virtuoso": "4.18.11",
    "sonner": "2.0.7",
    "typescript": "7.0.2"
  }
}
