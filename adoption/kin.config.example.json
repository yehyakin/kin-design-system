{
  "$schema": "https://raw.githubusercontent.com/yehyakin/kin-design-system/main/adoption/kin.config.schema.json",
  "kinVersion": "2.2.0",
  "profile": "information-site",
  "contract": {
    "source": "https://github.com/yehyakin/kin-design-system/tree/v2.2.0",
    "local": "docs/KIN-DESIGN.md",
    "revision": "v2.2.0",
    "checksum": "e7e32da9dcbc30b97568351c059c9dd3563478d38f1788ee615219608f549215"
  },
  "tokens": {
    "source": "src/styles/tokens.css",
    "format": "css",
    "generated": false
  },
  "components": {
    "roots": ["src/components"]
  },
  "delivery": {
    "mode": "contract-first",
    "figma": "variables-only",
    "runtime": "project-owned",
    "evidence": "docs/kin-evidence.json"
  },
  "audit": {
    "include": ["src"],
    "exclude": ["src/generated/**"],
    "exceptions": []
  },
  "verification": {
    "commands": ["npm run lint", "npm run typecheck", "npm test", "npm run build"]
  }
}
