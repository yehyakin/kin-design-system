{
  "$schema": "https://raw.githubusercontent.com/yehyakin/kin-design-system/main/adoption/kin.config.schema.json",
  "kinVersion": "2.3.0",
  "profile": "information-site",
  "contract": {
    "source": "https://github.com/yehyakin/kin-design-system/tree/v2.3.0",
    "local": "docs/KIN-DESIGN.md",
    "revision": "v2.3.0",
    "checksum": "cce89816242a32ff8545771616739dd32d4ab163990a4ba90c5adea54c0b994e"
  },
  "tokens": {
    "source": "src/styles/tokens.css",
    "format": "css",
    "generated": false
  },
  "components": {
    "roots": ["src/components"]
  },
  "scope": {
    "mode": "partial",
    "implementationBrief": "docs/kin-implementation-brief.md",
    "routeProfiles": [
      {
        "route": "/records/**",
        "profile": "information-site",
        "purpose": "Search, open, verify, and return to a published record.",
        "representative": true
      }
    ],
    "exclusions": []
  },
  "delivery": {
    "mode": "contract-first",
    "figma": "variables-only",
    "runtime": "project-owned",
    "evidence": "docs/kin-evidence.json"
  },
  "audit": {
    "include": ["src"],
    "exclude": ["src/generated/**"],
    "exceptions": []
  },
  "verification": {
    "commands": ["npm run lint", "npm run typecheck", "npm test", "npm run build"]
  }
}
