{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/yehyakin/kin-design-system/main/adoption/kin.config.schema.json",
  "title": "KIN adoption configuration",
  "type": "object",
  "required": ["kinVersion", "profile", "contract", "tokens", "audit", "verification"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "kinVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "profile": {
      "enum": ["information-site", "intelligence-workspace", "ecommerce-operations", "engineering-canvas"]
    },
    "contract": {
      "type": "object",
      "required": ["source", "local"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "local": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "tokens": {
      "type": "object",
      "required": ["source", "format", "generated"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "format": { "enum": ["css", "dtcg", "tailwind", "custom"] },
        "generated": { "type": "boolean" }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roots": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "delivery": {
      "type": "object",
      "required": ["mode", "figma", "runtime", "evidence"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "contract-first" },
        "figma": { "const": "variables-only" },
        "runtime": { "const": "project-owned" },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "audit": {
      "type": "object",
      "required": ["include", "exclude", "exceptions"],
      "additionalProperties": false,
      "properties": {
        "include": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "exclude": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rule", "path", "reason"],
            "additionalProperties": false,
            "properties": {
              "rule": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 12 }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "commands": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
